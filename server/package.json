{
  "name": "sop-server",
  "version": "1.0.0",
  "description": "SOP Management System - Express API",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "build": "DATABASE_URL=file:./dev.db prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "node src/prisma/seed.js",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma": "^5.14.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
