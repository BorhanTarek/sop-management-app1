// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String
  fullName           String
  department         String?
  isActive           Boolean   @default(true)
  hasSetSignature    Boolean   @default(false)
  hasChangedPassword Boolean   @default(false)
  signatureData      String?   // Base64 PNG of user's drawn signature
  signatureSetAt     DateTime? // Audit timestamp of last signature update
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  roles        UserRole[]
  ownedSops    Sop[]        @relation("SopOwner")
  createdSopVersions SopVersion[]
  changeLogs   ChangeLog[]
  createdCategories Category[]
  stepAcknowledgments StepAcknowledgment[]
  stationAssignments  UserStation[]
  sessions            SopSession[]
  workInstructionAcknowledgments WorkInstructionAcknowledgment[]
  checklistSubmissions ChecklistSubmission[]
  driverServiceForms   DriverServiceForm[]

  @@map("users")
}

model Role {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String?

  userRoles UserRole[]
  sopRoleVisibility SopRoleVisibility[]
  workInstructionRoleVisibility WorkInstructionRoleVisibility[]

  @@map("roles")
}

model UserRole {
  userId String
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  parentId    String?
  sortOrder   Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  sops     Sop[]
  createdBy User?     @relation(fields: [createdById], references: [id])

  @@map("categories")
}

model Sop {
  id             String   @id @default(uuid())
  title          String
  referenceCode  String?  @unique
  categoryId     String?
  ownerId        String?
  docType        String   @default("SOP")
  status         String   @default("draft")
  currentVersion String   @default("1.0")
  tags           String?  // JSON array stored as string for SQLite
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  publishedAt    DateTime?

  category   Category?    @relation(fields: [categoryId], references: [id])
  owner      User?        @relation("SopOwner", fields: [ownerId], references: [id])
  versions   SopVersion[]
  changeLogs ChangeLog[]
  steps      SopStep[]
  stepAcknowledgments StepAcknowledgment[]
  stationSops         StationSop[]
  sessions            SopSession[]
  roleVisibility      SopRoleVisibility[]

  @@map("sops")
}

model SopVersion {
  id          String   @id @default(uuid())
  sopId       String
  version     String
  contentJson String   // JSON stored as string
  contentHtml String?
  createdById String?
  createdAt   DateTime @default(now())
  isCurrent   Boolean  @default(false)

  sop       Sop      @relation(fields: [sopId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id])
  steps     SopStep[]

  @@unique([sopId, version])
  @@map("sop_versions")
}

model ChangeLog {
  id            String   @id @default(uuid())
  sopId         String
  versionFrom   String?
  versionTo     String
  changeSummary String
  changedById   String?
  changedAt     DateTime @default(now())

  sop       Sop   @relation(fields: [sopId], references: [id], onDelete: Cascade)
  changedBy User? @relation(fields: [changedById], references: [id])

  @@map("change_logs")
}

model SopStep {
  id              String   @id @default(uuid())
  sopId           String
  versionId       String?
  stepNumber      Int
  title           String?
  body            String?
  stepType        String   @default("action")  // action | safety_critical | decision | reference
  refCode         String?
  parentStepId    String?
  sortOrder       Int      @default(0)
  branchData      String?  // JSON: { yesBranch:[...], noBranch:[...] } for decision steps
  attentionPoints String?  // JSON array of ints e.g. [1,2] for P badges
  safetyPoints    String?  // JSON array of ints e.g. [1] for S badges

  sop       Sop         @relation(fields: [sopId], references: [id], onDelete: Cascade)
  version   SopVersion? @relation(fields: [versionId], references: [id])
  parent    SopStep?    @relation("StepTree", fields: [parentStepId], references: [id])
  children  SopStep[]   @relation("StepTree")

  @@map("sop_steps")
}

model StepAcknowledgment {
  id             String   @id @default(uuid())
  sopId          String
  stepId         String
  userId         String
  version        String
  acknowledgedAt DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sop            Sop      @relation(fields: [sopId], references: [id], onDelete: Cascade)

  @@map("step_acknowledgments")
}

// ═══════════════════════════════════════════════════════
// STATION PORTAL MODELS
// ═══════════════════════════════════════════════════════

model Station {
  id          String   @id @default(uuid())
  name        String
  nameAr      String?  // Arabic name
  stationCode String   @unique  // e.g. L3-001
  lineCode    String   @default("L3")  // Cairo Metro Line 3
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  openingTime String   @default("05:00")
  closingTime String   @default("23:00")
  createdAt   DateTime @default(now())

  userAssignments UserStation[]
  stationSops     StationSop[]
  sessions        SopSession[]
  checklistSubmissions ChecklistSubmission[]

  @@map("stations")
}

model UserStation {
  userId    String
  stationId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  station   Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@id([userId, stationId])
  @@map("user_stations")
}

model StationSop {
  id          String  @id @default(uuid())
  stationId   String
  sopId       String
  procedureType String  // "opening" | "closing"

  station     Station @relation(fields: [stationId], references: [id], onDelete: Cascade)
  sop         Sop     @relation(fields: [sopId], references: [id], onDelete: Cascade)

  @@unique([stationId, procedureType])
  @@map("station_sops")
}

model SopSession {
  id            String    @id @default(uuid())
  stationId     String?   // null for viewer-portal sessions
  sopId         String
  userId        String
  procedureType String    // "opening" | "closing" | "viewer"
  source        String    @default("station")  // "station" | "viewer"
  status        String    @default("in_progress")  // "in_progress" | "completed" | "abandoned"
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  shiftDate     String    // YYYY-MM-DD for grouping

  station       Station?        @relation(fields: [stationId], references: [id])
  sop           Sop             @relation(fields: [sopId], references: [id], onDelete: Cascade)
  user          User            @relation(fields: [userId], references: [id])
  stepLogs      SopSessionStep[]

  @@map("sop_sessions")
}

model SopSessionStep {
  id            String   @id @default(uuid())
  sessionId     String
  stepId        String
  stepTitle     String?
  stepType      String?  // action | safety_critical | decision | reference
  acknowledgedAt DateTime @default(now())
  branchChoice  String?  // "yes" | "no" for decision steps

  session       SopSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("sop_session_steps")
}

model SopRoleVisibility {
  sopId  String
  roleId Int

  sop  Sop  @relation(fields: [sopId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([sopId, roleId])
  @@map("sop_role_visibility")
}

model WorkInstruction {
  id          String   @id @default(uuid())
  title       String
  content     String
  imageUrl    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  acknowledgments WorkInstructionAcknowledgment[]
  roleVisibility WorkInstructionRoleVisibility[]

  @@map("work_instructions")
}

model WorkInstructionAcknowledgment {
  id                String   @id @default(uuid())
  workInstructionId String
  userId            String
  acknowledgedAt    DateTime @default(now())

  workInstruction   WorkInstruction @relation(fields: [workInstructionId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workInstructionId, userId])
  @@map("work_instruction_acknowledgments")
}

model WorkInstructionRoleVisibility {
  workInstructionId String
  roleId            Int

  workInstruction WorkInstruction @relation(fields: [workInstructionId], references: [id], onDelete: Cascade)
  role            Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([workInstructionId, roleId])
  @@map("work_instruction_role_visibility")
}

model ChecklistTask {
  id            String   @id @default(uuid())
  text          String
  procedureType String   // "opening" | "closing"
  controlType   String   @default("checkbox") // "checkbox" | "dropdown" | "action"
  options       String?  // JSON string array for dropdown options, e.g. ["Yes", "No"]
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("checklist_tasks")
}

model ChecklistSubmission {
  id            String   @id @default(uuid())
  userId        String
  stationId     String
  procedureType String   // "opening" | "closing"
  shiftDate     String   // YYYY-MM-DD for compliance grouping
  isCompliant   Boolean  @default(true)
  submittedAt   DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  station       Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  items         ChecklistSubmissionItem[]

  @@map("checklist_submissions")
}

model ChecklistSubmissionItem {
  id            String   @id @default(uuid())
  submissionId  String
  taskId        String
  taskText      String
  controlType   String   @default("checkbox")
  value         String   // Stores "true", "false", or dropdown selection, or text details

  submission    ChecklistSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("checklist_submission_items")
}

// ═══════════════════════════════════════════════════════
// DRIVER SERVICE FORM MODEL
// ═══════════════════════════════════════════════════════

model DriverServiceForm {
  id             String   @id @default(uuid())
  userId         String
  submittedAt    DateTime @default(now())
  shiftDate      String   // YYYY-MM-DD

  // ── Driver Details ──
  driverName     String
  driverId       String
  shiftStartTime String?
  shiftEndTime   String?
  shiftCode      String?
  trainType      String?
  overtimeHours  String?
  safetyNotice   String?  // free text note from safety notice board

  // ── Cycle Details (JSON array of trip rows) ──
  // [{trip, units, departure, departureTime, arrival, arrivalTime, remarks}]
  cycleDetails   String?

  // ── Persons Admitted in Cabin (JSON array, 4 rows) ──
  // [{nameId, driving, trip, departure, arrival}]
  cabinPersonnel String?

  // ── Degraded Operations Situations (JSON) ──
  // {signalsBypassing:[{origin,trip,signal,destination,formNumber}], movingInReverse:[...]}
  degradedOps    String?

  // ── DRI SOPs ──
  driSopsApplied String?
  ecoActuated    String?
  remarks        String?

  // ── Observation of Damage ──
  damageMainline       String?
  damageDepot          String?
  damageTime           String?
  rollingstockDamage   String?
  infraDamageSignaling String?
  infraDamageTrack     String?
  infraDamageOthers    String?

  // ── CCP Section ──
  ccpInstruction     String?
  ccpEcoActuated     String?
  ccpConfirmation    String?
  passengersInformed String?

  // ── Troubleshooting ──
  troubleshootingUnits    String?
  troSopsApplied          String?
  // JSON: {atcbs,dis,pibs,vsos,dmcb,eos,eebs,rbcs,hbcs,gbccos,zvrbs}
  isolatedSwitches        String?
  actionOnCBs             String?
  isolatedDoors           String?
  compressorsOutOfService String?
  vvvfsOutOfService       String?
  sivsOutOfService        String?

  // ── Isolated Brakes (JSON full matrix) ──
  // {dtcLeft:{sr1:{m,n1,t}, sr2:{m,n1,t}}, mc1Left:{...}, ...}
  isolatedBrakes String?

  // ── Train Movement Status ──
  activeBrakingBogiesFrom String?
  activeBrakingBogiesTo   String?
  speedRestrictions       String?
  pressureGaugeReading    String?
  trainService            String?  // "with_passengers" | "empty" | "rescue"

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driver_service_forms")
}
