// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  department   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles        UserRole[]
  ownedSops    Sop[]        @relation("SopOwner")
  createdSopVersions SopVersion[]
  changeLogs   ChangeLog[]
  createdCategories Category[]

  @@map("users")
}

model Role {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String?

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  userId String
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  parentId    String?
  sortOrder   Int      @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  sops     Sop[]
  createdBy User?     @relation(fields: [createdById], references: [id])

  @@map("categories")
}

model Sop {
  id             String   @id @default(uuid())
  title          String
  referenceCode  String?  @unique
  categoryId     String?
  ownerId        String?
  docType        String   @default("SOP")
  status         String   @default("draft")
  currentVersion String   @default("1.0")
  tags           String?  // JSON array stored as string for SQLite
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  publishedAt    DateTime?

  category   Category?    @relation(fields: [categoryId], references: [id])
  owner      User?        @relation("SopOwner", fields: [ownerId], references: [id])
  versions   SopVersion[]
  changeLogs ChangeLog[]
  steps      SopStep[]

  @@map("sops")
}

model SopVersion {
  id          String   @id @default(uuid())
  sopId       String
  version     String
  contentJson String   // JSON stored as string
  contentHtml String?
  createdById String?
  createdAt   DateTime @default(now())
  isCurrent   Boolean  @default(false)

  sop       Sop      @relation(fields: [sopId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id])
  steps     SopStep[]

  @@unique([sopId, version])
  @@map("sop_versions")
}

model ChangeLog {
  id            String   @id @default(uuid())
  sopId         String
  versionFrom   String?
  versionTo     String
  changeSummary String
  changedById   String?
  changedAt     DateTime @default(now())

  sop       Sop   @relation(fields: [sopId], references: [id], onDelete: Cascade)
  changedBy User? @relation(fields: [changedById], references: [id])

  @@map("change_logs")
}

model SopStep {
  id           String   @id @default(uuid())
  sopId        String
  versionId    String?
  stepNumber   Int
  title        String?
  body         String?
  stepType     String   @default("action")
  refCode      String?
  parentStepId String?
  sortOrder    Int      @default(0)

  sop       Sop         @relation(fields: [sopId], references: [id], onDelete: Cascade)
  version   SopVersion? @relation(fields: [versionId], references: [id])
  parent    SopStep?    @relation("StepTree", fields: [parentStepId], references: [id])
  children  SopStep[]   @relation("StepTree")

  @@map("sop_steps")
}
